# Studio UI - Production
# Copy to ui/.env before building

# --- Required (must configure) ---
# The public URL where users access the API (e.g., https://studio.yourdomain.com)
# REQUIRED - set this before deploying. The UI will not connect to the API if this is missing.
NEXT_PUBLIC_API_URL=

# REQUIRED - WebSocket URL (e.g., wss://studio.yourdomain.com)
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_API_ENV=production

# REQUIRED - server-side URL the SSR process uses to reach the API.
# Often the same as NEXT_PUBLIC_API_URL, but may differ if the UI container
# reaches the API over a private Docker network (e.g. http://api:8000).
SHS_API_BASE_URL=

PORT=3000
NEXT_TELEMETRY_DISABLED=1