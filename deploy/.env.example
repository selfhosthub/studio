# =============================================================================
# Studio - Production Environment Configuration
# Generated by studio-console. Edit with care.
# =============================================================================

# === COMPOSE PROJECT NAME ===
COMPOSE_PROJECT_NAME=studio

# === SECRETS - Required ===

# Generate with: openssl rand -hex 32
SHS_JWT_SECRET_KEY=
# Generate with: openssl rand -hex 32 (must match on API and all workers)
SHS_WORKER_SHARED_SECRET=
# Generate with: openssl rand -hex 32
SHS_CREDENTIAL_ENCRYPTION_KEY=

# === URLS ===

# nginx is always the front door. All URLs point at SHS_NGINX_PORT.
SHS_API_BASE_URL=http://localhost:80
SHS_PUBLIC_BASE_URL=http://localhost:80
SHS_FRONTEND_URL=http://localhost:80
SHS_CORS_ORIGINS=http://localhost:80
SHS_WS_URL=ws://localhost:80

# === NGINX ===

# Host port nginx listens on. This is the only port operators need to know.
SHS_NGINX_PORT=80

# === DATABASE ===

SHS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/selfhost_studio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# === WORKSPACE ===

# Where Studio's data lives on the host. Must be an absolute path.
# Defaults to ${HOME}/.studio if unset.
# SHS_WORKSPACE_HOST=
SHS_WORKSPACE_ROOT=/workspace

# === IMAGE VERSION ===

SHS_STUDIO_VERSION=1.0.0

# === API SETTINGS ===

SHS_ENV=production
SHS_DEBUG=false
SHS_LOG_LEVEL=WARNING
SHS_LOG_FORMAT=json
SHS_ENABLE_ACCESS_LOGS=false
SHS_SUPPRESS_WORKER_POLLING_LOGS=true
SHS_STORAGE_BACKEND=local
SHS_STORAGE_MODE=local
SHS_MAINTENANCE_MODE=false

# Content sources
SHS_COMMUNITY_SOURCE=https://raw.githubusercontent.com/selfhosthub/studio-community/main
SHS_PLUS_SOURCE=https://raw.githubusercontent.com/selfhosthub/studio-plus/main
SHS_CATALOG_CACHE_HOURS=168

# === SCALING ===

# Number of API/UI instances. Changing these regenerates docker-compose.override.yml.
SHS_API_REPLICAS=1
SHS_UI_REPLICAS=1

# === WORKER SETTINGS ===

SHS_WHISPER_MODEL=base
# SHS_COMFYUI_URL=http://your-comfyui-host:8188
